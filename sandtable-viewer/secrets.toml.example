# Copy to secrets.toml next to this file (it's gitignored) and fill in your
# OctoPrint API key — Settings -> Application Keys in OctoPrint, or reuse the
# one from the repo-root secrets.toml.

[octoprint]
url     = "http://127.0.0.1"   # viewer runs on the same Pi as OctoPrint
api_key = "PUT-YOUR-KEY-HERE"

[viewer]
bed_x = 370
bed_y = 400
port = 8099
poll_interval = 2.5
